# ============================================================
# Deep Search AI Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
# ============================================================

# --- LLM: OpenAI (required) --------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
DEFAULT_MODEL_PROVIDER=openai

# --- LLM: Qwen / Alibaba DashScope (optional) -------------
# Get key from: https://dashscope.console.aliyun.com/
# QWEN_API_KEY=your_qwen_api_key_here
# QWEN_MODEL=qwen-plus

# --- LLM: Ollama (optional, local) ------------------------
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# --- Search Provider (pick one) ----------------------------
# Option A: SerpAPI (default)
SERPAPI_API_KEY=your_serpapi_api_key_here
SERPAPI_GL=us
SERPAPI_HL=en
SERPAPI_SAFE=active

# Option B: Tavily
# SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=your_tavily_api_key_here

# --- Network / SSL -----------------------------------------
# Set to false if behind corporate proxy with self-signed certs
SSL_VERIFY=true

# --- Ports (Docker) ----------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000
