# ============================================================
# Deep Search AI Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control. It contains
# API keys and secrets. Ensure .env is in .gitignore.
# ============================================================

# --- LLM: OpenAI (required) --------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
DEFAULT_MODEL_PROVIDER=openai

# --- LLM: Qwen / Alibaba DashScope (optional) -------------
# Get key from: https://dashscope.console.aliyun.com/
# QWEN_API_KEY=your_qwen_api_key_here
# QWEN_MODEL=qwen-plus

# --- LLM: OpenRouter (optional) ---------------------------
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- LLM: Ollama (optional, local) ------------------------
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# --- Embedding Provider (optional) ------------------------
# EMBEDDING_PROVIDER=auto  # Options: auto, openai, openrouter, ollama, hash
# EMBEDDING_MODEL=text-embedding-3-small  # Model to use for embeddings
# OPENROUTER_EMBEDDING_KEY=your_key_here  # Only if using OpenRouter for embeddings

# --- Search Provider (pick one) ----------------------------
# Option A: SerpAPI (default)
SERPAPI_API_KEY=your_serpapi_api_key_here
SERPAPI_GL=us
SERPAPI_HL=en
SERPAPI_SAFE=active

# Option B: Tavily
# SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=your_tavily_api_key_here

# --- Network / SSL -----------------------------------------
# Set to false if behind corporate proxy with self-signed certs
SSL_VERIFY=true

# --- Ports (Docker) ----------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Authentication ----------------------------------------
# JWT secret key for token signing (generate a random string)
# You can generate one with: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here_use_openssl_rand_hex_32

# API key encryption key (generate a random string)
# You can generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=your_encryption_key_here
